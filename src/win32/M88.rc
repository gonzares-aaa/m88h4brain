    CONTROL         "無効",IDC_DIPSW_4L,"Button",BS_AUTORADIOBUTTON,140,35,
                    31,10
    LTEXT           "DELコード受信時(&D)",IDC_STATIC,5,45,64,8
    CONTROL         "処理する",IDC_DIPSW_5H,"Button",BS_AUTORADIOBUTTON | 
