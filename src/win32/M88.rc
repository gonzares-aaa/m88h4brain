    CONTROL         "無視する",IDC_DIPSW_5L,"Button",BS_AUTORADIOBUTTON,140,
                    45,45,10
    LTEXT           "パリティチェック(&P)",IDC_STATIC,5,55,58,8
    CONTROL         "パリティあり",IDC_DIPSW_6H,"Button",BS_AUTORADIOBUTTON | 
                    WS_GROUP,85,55,53,10
    CONTROL         "パリティ無し",IDC_DIPSW_6L,"Button",BS_AUTORADIOBUTTON,
                    140,55,54,10
    LTEXT           "パリティ指定(&Q)",IDC_STATIC,5,65,50,8
