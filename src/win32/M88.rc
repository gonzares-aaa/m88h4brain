/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MENU_M88 MENU DISCARDABLE 
BEGIN
    POPUP "&Control"
    BEGIN
        MENUITEM "&Reset\tF12",                 IDM_RESET
        MENUITEM SEPARATOR
        MENUITEM "N88-V&1(S) mode",             IDM_N88V1
        MENUITEM "N88-V1(&H) mode",             IDM_N88V1H
        MENUITEM "N88-V&2 mode",                IDM_N88V2
        MENUITEM "&N mode",                     IDM_NMODE
        MENUITEM "N8&0 mode",                   IDM_N80MODE
        MENUITEM SEPARATOR
        MENUITEM "N88-V2(C&D) mode",            IDM_N88V2CD
        MENUITEM SEPARATOR
        MENUITEM "&Configure...",               IDM_CONFIG
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       IDM_EXIT
    END
    POPUP "&Disk"
    BEGIN
        MENUITEM "Drive &1...",                 IDM_DRIVE_1
        MENUITEM "Drive &2...",                 IDM_DRIVE_2
        MENUITEM SEPARATOR
        MENUITEM "&Change both drive...",       IDM_BOTHDRIVE
    END
    POPUP "&Tools"
    BEGIN
        MENUITEM "Show S&tatus",                IDM_STATUSBAR
        MENUITEM "&Capture...\tAlt+F2",         IDM_CAPTURE
        MENUITEM "&Record Sound",               IDM_RECORDPCM
        MENUITEM SEPARATOR
        MENUITEM "&Save Snapshot\tAlt+F10",     IDM_SNAPSHOT_SAVE
        MENUITEM "&Load Snapshot\tAlt+F1",      IDM_SNAPSHOT_LOAD
    END
    POPUP "D&ebug"
    BEGIN
        MENUITEM "Show &FDC Status",            IDM_FDC_STATUS
        MENUITEM "Show &Register",              IDM_WATCHREGISTER
        MENUITEM "Show &OPN Register",          IDM_SOUNDMON
        MENUITEM "Show &Memory",                IDM_MEMMON
        MENUITEM "Show &Code",                  IDM_CODEMON
        MENUITEM SEPARATOR
        MENUITEM "Dump CPU&1 Log",              IDM_DUMPCPU1
        MENUITEM "Dump CPU&2 Log",              IDM_DUMPCPU2
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About...",                   IDM_ABOUTM88
    END
END

IDR_MENU_MEMORY MENU DISCARDABLE 
BEGIN
    POPUP "&0000"
    BEGIN
        MENUITEM "&RAM",                        IDM_MEM_0_RAM
        MENUITEM "N&88",                        IDM_MEM_0_N88
        MENUITEM "&N",                          IDM_MEM_0_N
    END
    POPUP "&6000"
    BEGIN
        MENUITEM "N&88",                        IDM_MEM_6_N88
        MENUITEM "E&0",                         IDM_MEM_6_E0
        MENUITEM "E&1",                         IDM_MEM_6_E1
        MENUITEM "E&2",                         IDM_MEM_6_E2
        MENUITEM "E&3",                         IDM_MEM_6_E3
    END
    POPUP "&f000"
    BEGIN
        MENUITEM "&RAM",                        IDM_MEM_F_RAM
        MENUITEM "&TVRAM",                      IDM_MEM_F_TVRAM
    END
END

IDR_MENU_DEBUG MENU DISCARDABLE 
BEGIN
    MENUITEM "&Text",                       IDM_DEBUG_TEXT
    MENUITEM "GVRAM&0",                     IDM_DEBUG_GVRAM0
    MENUITEM "GVRAM&1",                     IDM_DEBUG_GVRAM1
    MENUITEM "GVRAM&2",                     IDM_DEBUG_GVRAM2
END

IDR_MENU_M88P MENU DISCARDABLE 
BEGIN
    POPUP "&Control"
    BEGIN
        MENUITEM "&Reset",                      IDM_RESET
        MENUITEM SEPARATOR
		POPUP "Quick Save"
		BEGIN
			MENUITEM "Slot 1", IDM_QUICKSAVE_SLOT1
			MENUITEM "Slot 2", IDM_QUICKSAVE_SLOT2
			MENUITEM "Slot 3", IDM_QUICKSAVE_SLOT3
			MENUITEM "Slot 4", IDM_QUICKSAVE_SLOT4
			MENUITEM "Slot 5", IDM_QUICKSAVE_SLOT5
		END
		POPUP "Quick Load"
		BEGIN
			MENUITEM "Slot 1", IDM_QUICKLOAD_SLOT1
			MENUITEM "Slot 2", IDM_QUICKLOAD_SLOT2
			MENUITEM "Slot 3", IDM_QUICKLOAD_SLOT3
			MENUITEM "Slot 4", IDM_QUICKLOAD_SLOT4
			MENUITEM "Slot 5", IDM_QUICKLOAD_SLOT5
		END
        MENUITEM SEPARATOR
        MENUITEM "Mute"                         IDM_MUTE
        MENUITEM "Romaji input",                IDM_ROMAJI
        MENUITEM SEPARATOR
        MENUITEM "N88-V&1(S) mode",             IDM_N88V1
        MENUITEM "N88-V1(&H) mode",             IDM_N88V1H
        MENUITEM "N88-V&2 mode",                IDM_N88V2
        MENUITEM "&N mode",                     IDM_NMODE
        MENUITEM SEPARATOR
        MENUITEM "&Configure...",               0
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       IDM_EXIT
    END
    POPUP "&Disk"
    BEGIN
        POPUP "Drive &1..."
        BEGIN
            MENUITEM "Change &Disk",                IDM_DRIVE_1
            MENUITEM "Change &Image File...",       IDM_DRIVE_1_IC
        END
        POPUP "Drive &2..."
        BEGIN
            MENUITEM "Change &Disk",                IDM_DRIVE_2
            MENUITEM "Change &Image File...",       IDM_DRIVE_2_IC
        END
        MENUITEM SEPARATOR
        MENUITEM "&Change both drive...",       IDM_BOTHDRIVE
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About...",                   IDM_ABOUTM88
    END
END


/////////////////////////////////////////////////////////////////////////////
//
// Accelerator
//

IDR_ACC_M88UI ACCELERATORS DISCARDABLE 
BEGIN
    VK_DELETE,      IDM_LOGEND,             VIRTKEY, CONTROL, NOINVERT
    VK_F1,          IDM_SNAPSHOT_LOAD,      VIRTKEY, ALT, NOINVERT
    VK_F10,         IDM_SNAPSHOT_SAVE,      VIRTKEY, ALT, NOINVERT
    VK_F2,          IDM_CAPTURE,            VIRTKEY, ALT, NOINVERT
    VK_INSERT,      IDM_LOGSTART,           VIRTKEY, CONTROL, NOINVERT
    VK_RETURN,      IDM_TOGGLEDISPLAY,      VIRTKEY, ALT, NOINVERT
END


