IDD_ABOUT DIALOG DISCARDABLE  20, 20, 139, 121
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About M88"
FONT 10, "ＭＳ Ｐゴシック"
BEGIN
    LTEXT           "",IDC_ABOUT_TEXT,22,3,110,55
    ICON            IDI_ICON_M88,IDC_STATIC,5,5,20,20
    EDITTEXT        IDC_ABOUT_BOX,22,70,110,39,ES_MULTILINE | ES_AUTOVSCROLL | 
                    ES_READONLY | ES_WANTRETURN | WS_VSCROLL
END

IDD_CONFIG_CPU DIALOG DISCARDABLE  0, 0, 195, 127
STYLE WS_CHILD | WS_DISABLED | WS_CAPTION
CAPTION "CPU"
FONT 10, "ＭＳ Ｐゴシック"
BEGIN
    GROUPBOX        "速度",IDC_STATIC,5,5,185,40
    LTEXT           "動作周波数(&C)",IDC_STATIC,10,15,49,8
    EDITTEXT        IDC_CPU_CLOCK,60,15,20,12,ES_RIGHT | ES_NUMBER | 
                    WS_GROUP
    CONTROL         "Spin1",IDC_CPU_CLOCK_SPIN,"msctls_updown32",
                    UDS_SETBUDDYINT | UDS_AUTOBUDDY | UDS_ARROWKEYS | 
                    UDS_NOTHOUSANDS,80,15,11,10
    LTEXT           "MHz",IDC_STATIC,95,15,15,8
    LTEXT           "倍率(&B)",IDC_CPU_SPEED_TITLE,10,30,26,8
    CONTROL         "Slider1",IDC_CPU_SPEED,"msctls_trackbar32",TBS_BOTH | 
                    TBS_NOTICKS | WS_TABSTOP,40,30,50,10
    LTEXT           "0",IDC_CPU_SPEED_TEXT,90,30,20,8,0,WS_EX_RIGHT
    CONTROL         "全力駆動(&M)",IDC_CPU_NOWAIT,"Button",BS_AUTOCHECKBOX | 
                    WS_TABSTOP,120,15,55,10
    CONTROL         "速度調整省略(&N)",IDC_CPU_BURST,"Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,120,30,65,10
    GROUPBOX        "主副 CPU 速度比(&R)",IDC_STATIC,5,50,115,25
    CONTROL         "1:1",IDC_CPU_MS11,"Button",BS_AUTORADIOBUTTON | 
                    WS_GROUP,10,60,26,10
    CONTROL         "2:1",IDC_CPU_MS21,"Button",BS_AUTORADIOBUTTON,45,60,26,
                    10
    CONTROL         "自動",IDC_CPU_MSAUTO,"Button",BS_AUTORADIOBUTTON,80,60,
                    31,10
    GROUPBOX        "互換性",IDC_STATIC,5,80,105,35
    CONTROL         "Sub CPU を常に駆動(&S)",IDC_CPU_NOSUBCPUCONTROL,"Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,10,90,95,10
    CONTROL         "ウェイト(&W)",IDC_CPU_ENABLEWAIT,"Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,10,100,50,10
END

